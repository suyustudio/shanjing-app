generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举定义 ====================

enum TrailDifficulty {
  EASY
  MODERATE
  HARD
}

// ==================== 用户表 ====================

model User {
  id            String    @id @default(uuid())
  phone         String?   @unique
  passwordHash  String?   @map("password_hash")
  wxOpenid      String?   @unique @map("wx_openid")
  wxUnionid     String?   @unique @map("wx_unionid")
  nickname      String?
  avatarUrl     String?   @map("avatar_url")
  settings      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  favorites     Favorite[]
  
  @@index([phone])
  @@index([wxOpenid])
  @@map("users")
}

// ==================== 路线表 ====================

model Trail {
  id                String          @id @default(uuid())
  name              String
  description       String?
  distanceKm        Float
  durationMin       Int
  elevationGainM    Int
  difficulty        TrailDifficulty
  tags              String[]
  coverImages       String[]
  gpxUrl            String?
  city              String
  district          String
  startPointLat     Float
  startPointLng     Float
  startPointAddress String?
  safetyInfo        Json?
  boundsNorth       Float?
  boundsSouth       Float?
  boundsEast        Float?
  boundsWest        Float?
  isActive          Boolean         @default(true)
  createdBy         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  
  pois              TrailPoi[]
  favorites         Favorite[]
}

model TrailPoi {
  id          String   @id @default(uuid())
  trailId     String
  name        String
  description String?
  lat         Float
  lng         Float
  type        String
  order       Int
  createdAt   DateTime @default(now())
  
  trail       Trail    @relation(fields: [trailId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  trailId   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  trail     Trail    @relation(fields: [trailId], references: [id])
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== Token 黑名单 ====================

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
